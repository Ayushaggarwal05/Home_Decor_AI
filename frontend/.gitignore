# ─────────────────────────────────────────────
# Aura AI Frontend — Next.js / TypeScript .gitignore
# ─────────────────────────────────────────────

# ── Dependencies ─────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ─────────────────────
.next/
out/
build/

# ── Testing & coverage ────────────────────────
coverage/
.nyc_output/
junit.xml

# ── Environment / Secrets ────────────────────
.env
.env.*
!.env.example
!.env.*.example
*.pem

# ── TypeScript build cache ───────────────────
*.tsbuildinfo
next-env.d.ts
tsconfig.tsbuildinfo

# ── Vercel deployment ────────────────────────
.vercel

# ── Debug logs ───────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── OS artifacts ─────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ── IDE / Editor ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Storybook (if added later) ───────────────
storybook-static/

# ── Generated / cache ────────────────────────
.cache/
.turbo/
.eslintcache
.stylelintcache
