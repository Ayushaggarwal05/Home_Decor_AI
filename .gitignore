# ─────────────────────────────────────────────
# Aura AI — Root Monorepo .gitignore
# ─────────────────────────────────────────────

# ── OS artifacts ─────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*~

# ── Environment / Secrets ────────────────────
# Keep .env.example files; ignore all real env files
.env
.env.*
!.env.example
!.env.*.example

# ── Docker overrides (local only) ────────────
docker-compose.override.yml
docker-compose.local.yml

# ── Logs ─────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Temporary files ──────────────────────────
*.tmp
*.temp
.cache/
